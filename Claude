/* ─── Model: Fractal (Julia Set) ─── */
function JuliaFractal({ width, height }) {
const ref = useRef(null);
useEffect(() => {
const c = ref.current; if (!c) return;
c.width = width; c.height = height;
const ctx = c.getContext(“2d”);
let raf, frame = 0;
const draw = (t) => {
const time = t * 0.0003;
const cr = -0.7 + Math.sin(time) * 0.15;
const ci = 0.27015 + Math.cos(time * 0.7) * 0.08;
const img = ctx.createImageData(width, height);
const d = img.data;
for (let px = 0; px < width; px += 2) {
for (let py = 0; py < height; py += 2) {
let zr = (px - width / 2) / (width / 3.5);
let zi = (py - height / 2) / (height / 3.5);
let iter = 0;
const maxIter = 60;
while (zr * zr + zi * zi < 4 && iter < maxIter) {
const tmp = zr * zr - zi * zi + cr;
zi = 2 * zr * zi + ci;
zr = tmp;
iter++;
}
const idx = (py * width + px) * 4;
if (iter < maxIter) {
const hue = (iter / maxIter) * 360 + 240;
const sat = 80;
const light = 30 + (iter / maxIter) * 50;
const [r, g, b] = hslToRgb(hue, sat, light);
for (let dx = 0; dx < 2; dx++) for (let dy = 0; dy < 2; dy++) {
const i = ((py + dy) * width + (px + dx)) * 4;
d[i] = r; d[i + 1] = g; d[i + 2] = b; d[i + 3] = 255;
}
}
}
}
ctx.putImageData(img, 0, 0);
ctx.fillStyle = “rgba(200,180,240,0.5)”; ctx.font = “10px monospace”;
ctx.fillText(`Julia Set  c = ${cr.toFixed(3)} + ${ci.toFixed(3)}i`, 10, 20);
raf = requestAnimationFrame(draw);
};
raf = requestAnimationFrame(draw);
return () => cancelAnimationFrame(raf);
}, [width, height]);
return <canvas ref={ref} style={{ width: “100%”, height: “100%”, borderRadius: 12 }} />;
}

function hslToRgb(h, s, l) {
h = h % 360; s /= 100; l /= 100;
const c = (1 - Math.abs(2 * l - 1)) * s;
const x = c * (1 - Math.abs((h / 60) % 2 - 1));
const m = l - c / 2;
let r, g, b;
if (h < 60) [r, g, b] = [c, x, 0]; else if (h < 120) [r, g, b] = [x, c, 0];
else if (h < 180) [r, g, b] = [0, c, x]; else if (h < 240) [r, g, b] = [0, x, c];
else if (h < 300) [r, g, b] = [x, 0, c]; else [r, g, b] = [c, 0, x];
return [Math.round((r + m) * 255), Math.round((g + m) * 255), Math.round((b + m) * 255)];
}

/* ─── Model: Spring Physics ─── */
function SpringPhysics({ width, height }) {
const ref = useRef(null);
useEffect(() => {
const c = ref.current; if (!c) return;
c.width = width; c.height = height;
const ctx = c.getContext(“2d”);
const particles = Array.from({ length: 12 }, (_, i) => ({
x: width / 2, y: 50 + i * 30, vx: 0, vy: 0, restY: 50 + i * 30,
restX: width / 2
}));
let mouse = { x: width / 2, y: height / 2, down: false };
const handleMove = (e) => {
const rect = c.getBoundingClientRect();
mouse.x = (e.clientX || e.touches?.[0]?.clientX || 0) - rect.left;
mouse.y = (e.clientY || e.touches?.[0]?.clientY || 0) - rect.top;
};
c.addEventListener(“mousemove”, handleMove);
c.addEventListener(“touchmove”, handleMove);
let raf;
const draw = (t) => {
ctx.clearRect(0, 0, width, height);
const time = t * 0.003;
// update springs
particles.forEach((p, i) => {
const targetX = width / 2 + Math.sin(time + i * 0.5) * 40;
const targetY = 50 + i * 30 + Math.cos(time * 0.7 + i * 0.3) * 15;
// mouse repulsion
const dx = p.x - mouse.x, dy = p.y - mouse.y;
const dist = Math.sqrt(dx * dx + dy * dy);
if (dist < 100) {
p.vx += (dx / dist) * 2;
p.vy += (dy / dist) * 2;
}
p.vx += (targetX - p.x) * 0.03;
p.vy += (targetY - p.y) * 0.03;
p.vx *= 0.92; p.vy *= 0.92;
p.x += p.vx; p.y += p.vy;
});
// draw connections
for (let i = 0; i < particles.length - 1; i++) {
const a = particles[i], b = particles[i + 1];
const dist = Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
const tension = Math.min(dist / 50, 1);
ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
ctx.strokeStyle = `rgba(${150 + tension * 105}, ${80 - tension * 50}, 255, 0.6)`;
ctx.lineWidth = 2 - tension; ctx.stroke();
// spring coils
const steps = 8;
ctx.beginPath();
for (let s = 0; s <= steps; s++) {
const t2 = s / steps;
const mx = a.x + (b.x - a.x) * t2 + Math.sin(t2 * Math.PI * 4) * (10 - tension * 8);
const my = a.y + (b.y - a.y) * t2;
s === 0 ? ctx.moveTo(mx, my) : ctx.lineTo(mx, my);
}
ctx.strokeStyle = `rgba(180,120,255,0.3)`; ctx.lineWidth = 1; ctx.stroke();
}
// draw particles
particles.forEach((p, i) => {
const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, 12);
grd.addColorStop(0, COLORS.accent1); grd.addColorStop(1, “rgba(180,80,255,0)”);
ctx.beginPath(); ctx.arc(p.x, p.y, 12, 0, Math.PI * 2); ctx.fillStyle = grd; ctx.fill();
ctx.beginPath(); ctx.arc(p.x, p.y, 4, 0, Math.PI * 2); ctx.fillStyle = “#e0b0ff”; ctx.fill();
});
ctx.fillStyle = “rgba(200,180,240,0.4)”; ctx.font = “10px monospace”;
ctx.fillText(“Spring-Mass System (move mouse to interact)”, 10, height - 12);
raf = requestAnimationFrame(draw);
};
raf = requestAnimationFrame(draw);
return () => { cancelAnimationFrame(raf); c.removeEventListener(“mousemove”, handleMove); c.removeEventListener(“touchmove”, handleMove); };
}, [width, height]);
return <canvas ref={ref} style={{ width: “100%”, height: “100%”, borderRadius: 12, cursor: “crosshair” }} />;
}

