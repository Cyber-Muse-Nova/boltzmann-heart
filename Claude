// probability density - double slit
for (let x = 0; x < width; x += 2) {
for (let y = 0; y < height; y += 2) {
const dx1 = x - width * 0.4, dy1 = y - height / 2 - 30;
const dx2 = x - width * 0.4, dy2 = y - height / 2 + 30;
const r1 = Math.sqrt(dx1 * dx1 + dy1 * dy1);
const r2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);
const wave1 = Math.sin(r1 * 0.08 - time * 2) / (1 + r1 * 0.01);
