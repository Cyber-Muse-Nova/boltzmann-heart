/* ─── Model: Lorenz Attractor ─── */
function LorenzAttractor({ width, height }) {
const ref = useRef(null);
useEffect(() => {
const c = ref.current; if (!c) return;
c.width = width; c.height = height;
const ctx = c.getContext(“2d”);
let x = 0.1, y = 0, z = 0;
const dt = 0.005, sigma = 10, rho = 28, beta = 8 / 3;
const points = [];
for (let i = 0; i < 8000; i++) {
const dx = sigma * (y - x) * dt;
const dy = (x * (rho - z) - y) * dt;
const dz = (x * y - beta * z) * dt;
x += dx; y += dy; z += dz;
points.push({ x, y, z });
}
let idx = 0, raf;
const draw = (t) => {
ctx.fillStyle = “rgba(10,5,21,0.03)”;
ctx.fillRect(0, 0, width, height);
const rotY = t * 0.0002;
const batch = 40;
for (let b = 0; b < batch && idx < points.length; b++, idx++) {
const p = points[idx];
const rx = p.x * Math.cos(rotY) - p.z * Math.sin(rotY);
const rz = p.x * Math.sin(rotY) + p.z * Math.cos(rotY);
const sx = width / 2 + rx * 7;
const sy = height / 2 - p.y * 7 + rz * 2;
const hue = 270 + (idx / points.length) * 60;
ctx.beginPath(); ctx.arc(sx, sy, 1, 0, Math.PI * 2);
ctx.fillStyle = `hsla(${hue}, 80%, 65%, 0.8)`;
ctx.fill();
}
if (idx >= points.length) idx = 0;
raf = requestAnimationFrame(draw);
};
raf = requestAnimationFrame(draw);
return () => cancelAnimationFrame(raf);
}, [width, height]);
return <canvas ref={ref} style={{ width: “100%”, height: “100%”, borderRadius: 12 }} />;
}

/* ─── Model: Quantum Wave ─── */
function QuantumWave({ width, height }) {
